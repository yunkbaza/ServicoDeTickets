{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": { "Path": "/api/events/{**catch-all}" }
      },
      "reservation-route": {
        "ClusterId": "reservation-cluster",
        "Match": { "Path": "/api/reservations/{**catch-all}" }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": { "Path": "/api/payment/{**catch-all}" }
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": { "catalog-api": { "Address": "http://localhost:5222" } }
      },
      "reservation-cluster": {
        "Destinations": { "reservation-api": { "Address": "http://localhost:5001" } }
      },
      "payment-cluster": {
        "Destinations": { "payment-api": { "Address": "http://localhost:5002" } }
      },
      "auth-cluster": {
        "Destinations": { "auth-api": { "Address": "http://localhost:5300" } }
      }
    }
  }
}